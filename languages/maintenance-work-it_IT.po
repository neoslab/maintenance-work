#: admin/class-maintenance-work-admin.php:74
msgid "Maintenance Work"
msgstr "Maintenance Work"

#: admin/class-maintenance-work-admin.php:86
msgid "Settings"
msgstr "Impostazioni"

#: admin/partials/maintenance-work-admin-options.php:4
msgid "Your settings have been successfully updated."
msgstr "Le tue impostazioni sono state aggiornate con successo."

#: admin/partials/maintenance-work-admin-options.php:10
msgid "The maintenance page status is not valid !!"
msgstr "Lo stato della pagina di manutenzione non è valido!!"

#: admin/partials/maintenance-work-admin-options.php:14
msgid "The maintenance page title is not valid !!"
msgstr "Il titolo della pagina di manutenzione non è valido!!"

#: admin/partials/maintenance-work-admin-options.php:18
msgid "The maintenance page description is not valid !!"
msgstr "La descrizione della pagina di manutenzione non è valida!!"

#: admin/partials/maintenance-work-admin-options.php:22
msgid "An unknown error occured !!"
msgstr "Si è verificato un errore sconosciuto!!"

#: admin/partials/maintenance-work-admin-options.php:42
msgid "Your maintenance page is currently switched-off ! In order to switch it on, please use the below form."
msgstr "La tua pagina di manutenzione è attualmente disattivata! Per attivarla, utilizza il modulo sottostante."

#: admin/partials/maintenance-work-admin-options.php:47
msgid "Your maintenance page is currently switched-on ! In order to switch it off, please use the below form."
msgstr "La tua pagina di manutenzione è attualmente attivata! Per disattivarla, utilizza il modulo sottostante."

#: admin/partials/maintenance-work-admin-options.php:56
msgid "Maintenance Mode"
msgstr "Modalità Manutenzione"

#: admin/partials/maintenance-work-admin-options.php:64
msgid "Do you want to switch your website under maintenance mode ?"
msgstr "Vuoi mettere il tuo sito web in modalità manutenzione?"

#: admin/partials/maintenance-work-admin-options.php:69
msgid "Page Title"
msgstr "Titolo Pagina"

#: admin/partials/maintenance-work-admin-options.php:70
msgid "Enter the page title"
msgstr "Inserisci il titolo della pagina"

#: admin/partials/maintenance-work-admin-options.php:71
msgid "Enter the page title as you want it to appear on the maintenance page displayed to your visitors."
msgstr "Inserisci il titolo della pagina come vuoi che appaia sulla pagina di manutenzione visualizzata dai tuoi visitatori."

#: admin/partials/maintenance-work-admin-options.php:75
msgid "Page Description"
msgstr "Descrizione Pagina"

#: admin/partials/maintenance-work-admin-options.php:76
msgid "Enter the page description"
msgstr "Inserisci la descrizione della pagina"

#: admin/partials/maintenance-work-admin-options.php:77
msgid "Enter the description as you want it to appear on the maintenance page displayed to your visitors."
msgstr "Inserisci la descrizione come vuoi che appaia sulla pagina di manutenzione visualizzata dai tuoi visitatori."

#: admin/partials/maintenance-work-admin-options.php:81
msgid "Update Settings"
msgstr "Aggiorna Impostazioni"

#: public/templates/page.php:26
msgid "Refresh Page"
msgstr "Aggiorna Pagina"

#. Plugin URI of the plugin/theme
msgid "https://wordpress.org/plugins/maintenance-work/"
msgstr "https://wordpress.org/plugins/maintenance-work/"

#. Description of the plugin/theme
msgid "Add a maintenance page to your website that lets visitors know your page is down for maintenance and allowing to work on beside of this."
msgstr "Aggiungi una pagina di manutenzione al tuo sito web per informare i visitatori che il sito è in manutenzione e permetterti di lavorare parallelamente."

#. Author of the plugin/theme
msgid "NeosLab"
msgstr "NeosLab"

